<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %> - Recovery Hub</title>
    <link rel="icon" href="<%= ctx.urlForFile('favicon.svg') %>">
    <link rel="stylesheet" href="<%= ctx.urlForFile('app.css') %>">
    <script src="<%= ctx.urlForFile('js/htmx.min.js') %>" defer></script>
  </head>
  <body>
    <header class="topbar">
      <a class="brand" href="/">
        <span class="pixel-icon brand-icon" aria-hidden="true"><svg class="pixel-symbol"><use href="/static/icons.svg#icon-heart"></use></svg></span>
        <span>Recovery Hub</span>
      </a>
      <nav class="desktop-nav" aria-label="Main">
        <a class="nav-button <%= active === 'home' ? 'active' : '' %>" href="/"><svg class="button-icon" aria-hidden="true"><use href="/static/icons.svg#icon-home"></use></svg> Home</a>
        <a class="nav-button <%= active === 'stage' ? 'active' : '' %>" href="/stage"><svg class="button-icon" aria-hidden="true"><use href="/static/icons.svg#icon-stage"></use></svg> Stage</a>
        <a class="nav-button <%= active === 'explore' ? 'active' : '' %>" href="/explore"><svg class="button-icon" aria-hidden="true"><use href="/static/icons.svg#icon-explore"></use></svg> Explore</a>
        <a class="nav-button <%= active === 'log' ? 'active' : '' %>" href="/log/new"><svg class="button-icon" aria-hidden="true"><use href="/static/icons.svg#icon-log"></use></svg> Log</a>
        <a class="nav-button <%= active === 'account' || active === 'context' ? 'active' : '' %>" href="/account"><svg class="button-icon" aria-hidden="true"><use href="/static/icons.svg#icon-account"></use></svg> Account</a>
      </nav>
      <% if (ctx.stash.profileName) { %>
        <a class="nav-button fx-button session-button" href="/logout"><svg class="button-icon" aria-hidden="true"><use href="/static/icons.svg#icon-gear"></use></svg><span><%= ctx.stash.profileName %></span><small>Logout</small></a>
      <% } else { %>
        <span class="nav-button fx-button"><svg class="button-icon" aria-hidden="true"><use href="/static/icons.svg#icon-gear"></use></svg> FX</span>
      <% } %>
    </header>

    <main class="page-shell">
      <%= ctx.content.main %>
    </main>

    <nav class="mobile-nav" aria-label="Mobile main">
      <a class="<%= active === 'home' ? 'active' : '' %>" href="/"><svg class="button-icon" aria-hidden="true"><use href="/static/icons.svg#icon-home"></use></svg><small>Home</small></a>
      <a class="<%= active === 'stage' ? 'active' : '' %>" href="/stage"><svg class="button-icon" aria-hidden="true"><use href="/static/icons.svg#icon-stage"></use></svg><small>Stage</small></a>
      <a class="<%= active === 'explore' ? 'active' : '' %>" href="/explore"><svg class="button-icon" aria-hidden="true"><use href="/static/icons.svg#icon-explore"></use></svg><small>Explore</small></a>
      <a class="<%= active === 'log' ? 'active' : '' %>" href="/log/new"><svg class="button-icon" aria-hidden="true"><use href="/static/icons.svg#icon-log"></use></svg><small>Log</small></a>
      <a class="<%= active === 'account' || active === 'context' ? 'active' : '' %>" href="/account"><svg class="button-icon" aria-hidden="true"><use href="/static/icons.svg#icon-account"></use></svg><small>Account</small></a>
    </nav>
  </body>
</html>
