<section id="explore-results" class="screen-grid explore-grid" aria-live="polite">
  <article class="panel">
    <header><span class="pixel-icon" aria-hidden="true"><svg class="pixel-symbol"><use href="/static/icons.svg#icon-people"></use></svg></span><strong>Similar people</strong></header>
    <div class="panel-body compact-list">
      % for (const person of similarPeople) {
        <div class="list-item">
          <span class="pixel-icon small" aria-hidden="true"><svg class="pixel-symbol"><use href="/static/icons.svg#icon-account"></use></svg></span>
          <span><strong><%= person.display_name %></strong><small><%= person.body_area %>, <%= person.recovery_stage %>, <%= person.activity_goal %></small></span>
        </div>
      % }
      % if (similarPeople.length === 0) {
        <p>No exact people match yet. Try fewer filters.</p>
      % }
    </div>
  </article>

  <article class="panel list-panel">
    <header><span class="pixel-icon" aria-hidden="true"><svg class="pixel-symbol"><use href="/static/icons.svg#icon-log"></use></svg></span><strong>Recovery logs</strong></header>
    <div class="panel-body compact-list">
      % for (const log of logs) {
        <a class="list-item" href="/detail/log/<%= log.recovery_log_id %>">
          <span class="pixel-icon small" aria-hidden="true"><svg class="pixel-symbol"><use href="/static/icons.svg#icon-movement"></use></svg></span>
          <span><strong><%= log.title %></strong><small><%= log.body_area %>, <%= log.recovery_stage %> · pain <%= log.pain_before %> → <%= log.pain_after %></small></span>
        </a>
      % }
      % if (logs.length === 0) {
        <p>No logs match these filters.</p>
      % }
    </div>
  </article>

  <article class="panel list-panel">
    <header><span class="pixel-icon" aria-hidden="true"><svg class="pixel-symbol"><use href="/static/icons.svg#icon-question"></use></svg></span><strong>Discussions</strong></header>
    <div class="panel-body compact-list">
      % for (const thread of threads) {
        <a class="list-item" href="/detail/thread/<%= thread.discussion_thread_id %>">
          <span class="pixel-icon small" aria-hidden="true"><svg class="pixel-symbol"><use href="/static/icons.svg#icon-question"></use></svg></span>
          <span><strong><%= thread.title %></strong><small><%= thread.body_area %>, <%= thread.recovery_stage %> · <%= thread.status %></small></span>
        </a>
      % }
      % if (threads.length === 0) {
        <p>No discussions match these filters.</p>
      % }
    </div>
  </article>

  <article class="panel">
    <header><span class="pixel-icon" aria-hidden="true"><svg class="pixel-symbol"><use href="/static/icons.svg#icon-shield"></use></svg></span><strong>Discovery rule</strong></header>
    <div class="panel-body">
      <p>Explore owns the "find BlaBla members recovering at your stage" task. Home stays focused on status and next action.</p>
      <div class="tag-row">
        <span class="tag"><svg class="tag-icon" aria-hidden="true"><use href="/static/icons.svg#icon-explore"></use></svg>Discovery</span>
        <span class="tag"><svg class="tag-icon" aria-hidden="true"><use href="/static/icons.svg#icon-stage"></use></svg>Stage match</span>
      </div>
    </div>
  </article>
</section>
